{
  "name": "orbit-flutter",
  "displayName": "Orbit Flutter State Management",
  "description": "VS Code extension for Orbit — Flutter state management inspector, snippets, and store generator",
  "version": "1.3.0",
  "publisher": "orbit",
  "icon": "orbit.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Snippets",
    "Other"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:dart",
    "onCommand:orbit.createStore",
    "onView:orbit.stateInspector"
  ],
  "contributes": {
    "commands": [
      {
        "command": "orbit.createStore",
        "title": "Orbit: Create OrbitStore"
      }
    ],
    "snippets": [
      {
        "language": "dart",
        "path": "./snippets/snippets.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "orbit-sidebar",
          "title": "Orbit State",
          "icon": "orbit.png"
        }
      ]
    },
    "views": {
      "orbit-sidebar": [
        {
          "type": "webview",
          "id": "orbit.stateInspector",
          "name": "Orbit Stores"
        }
      ]
    }
  },
  "scripts": {
    "package": "vsce package --allow-missing-repository"
  }
}
